{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EaWSL",
  "version": "0.2.0",
  "identifier": "com.eawsl.app",
  "build": {
    "beforeDevCommand": "pnpm frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm frontend:build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "EaWSL",
        "width": 1360,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["tabbed"]
        },
        "shadow": true,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
