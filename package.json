{
  "name": "eawsl",
  "version": "0.1.0",
  "private": true,
  "description": "EaWSL desktop app shell",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "frontend:dev": "vite dev",
    "frontend:build": "vite build",
    "format": "cargo fmt --all && prettier --plugin prettier-plugin-svelte --write \"src/**/*.{js,ts,svelte,css,json}\" \"src-tauri/**/*.json\" \"wsl-core/tests/fixtures/**/*.json\" \"package.json\" \"pnpm-lock.yaml\" \"tsconfig.json\" \"svelte.config.js\" \"vite.config.js\"",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.8.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^18.19.130",
    "prettier": "^3.8.0",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^6.0.3"
  }
}